{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Orders": {
    "MaxLinesPerOrder": 50,
    "MinOrderAmount": 10.00,
    "AllowBackorders": false,
    "RetentionDays": 365,
    "Currency": "EUR"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Orders.API": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
