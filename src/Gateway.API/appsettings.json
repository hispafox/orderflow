{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Yarp": "Warning"
      }
    }
  },
  "Jwt": {
    "Issuer":        "orderflow-gateway",
    "Audience":      "orderflow",
    "ExpiryMinutes": "60",
    "SigningKey":     "← desde User Secrets (dev) o Key Vault (prod)"
  },
  "KeyVault": {
    "Uri": "← desde appsettings.Production.json"
  },
  "ReverseProxy": {
    "Routes": {
      "orders-create-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/orders",
          "Methods": [ "POST" ]
        },
        "AuthorizationPolicy": "CustomerOrAdmin",
        "RateLimiterPolicy": "CreateOrder",
        "Transforms": [
          { "RequestHeadersCopy": "true" },
          { "RequestHeader": "X-Gateway-Source", "Set": "orderflow-gateway" }
        ]
      },
      "orders-read-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}",
          "Methods": [ "GET", "POST" ]
        },
        "AuthorizationPolicy": "CustomerOrAdmin",
        "RateLimiterPolicy": "SmartRateLimit",
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        },
        "RateLimiterPolicy": "SmartRateLimit",
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      },
      "payments-route": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        },
        "AuthorizationPolicy": "AdminOnly",
        "RateLimiterPolicy": "PerIp",
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "AuthorizationPolicy": "AdminOnly"
      }
    },
    "Clusters": {
      "orders-cluster": {
        "HttpRequest": {
          "Timeout": "00:00:30",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "primary": { "Address": "http://orders-api" }
        }
      },
      "products-cluster": {
        "HttpRequest": { "Timeout": "00:00:15" },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "primary": { "Address": "http://products-api" }
        }
      },
      "payments-cluster": {
        "HttpRequest": { "Timeout": "00:00:30" },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "primary": { "Address": "http://payments-api" }
        }
      },
      "notifications-cluster": {
        "HttpRequest": { "Timeout": "00:00:15" },
        "Destinations": {
          "primary": { "Address": "http://notifications-api" }
        }
      }
    }
  }
}
