{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Products": {
    "MaxStock": 100000,
    "LowStockThreshold": 10,
    "AllowBackorders": false,
    "DefaultCurrency": "EUR"
  },
  "AllowedHosts": "*"
}
